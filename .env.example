# Optional: required only for real local CABT play.
# Point this at the Kaggle-provided sample_submission directory.
CABT_SAMPLE_SUBMISSION_DIR=/absolute/path/to/sample_submission

# Optional: user-supplied card images.
# Leave unset to run without card art or card-back images.
#
# Recommended: one manifest for card faces, card backs, and energy symbols.
# Manifest image URLs may be local public paths or absolute HTTPS URLs you host.
# VITE_CABT_VISUAL_ASSET_MANIFEST=/local-card-images/manifest.json
#
# Scrydex card-face URLs. Leave unset to render card text placeholders.
# VITE_CABT_CARD_IMAGE_SOURCE=scrydex
#
# Custom local/remote template. This overrides the preset source when set.
# Example: https://assets.example.com/cabt/cards/{set}/{number}.png
# Available tokens: {set}, {setId}, {number}, {numberPadded}, {name}, {fullName}
# VITE_CABT_CARD_IMAGE_TEMPLATE=/local-card-images/{set}/{number}.png
#
# Card backs default to Scrydex when Scrydex card images are enabled.
# Set this only to override that default.
# VITE_CABT_CARD_BACK_IMAGE_URL=/local-card-images/cardback.png
#
# Optional override for image-backed energy symbols. Leave unset to use bundled
# energy symbol images when card images are enabled.
# Available tokens: {type}, {name}, {slug}
# VITE_CABT_ENERGY_IMAGE_TEMPLATE=/local-card-images/energy/{slug}.webp
